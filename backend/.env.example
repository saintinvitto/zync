PORT=3001
DATABASE_URL=postgresql://postgres:SUASENHA@db.xxxxxxxxxxxx.supabase.co:5432/postgres
JWT_SECRET=troque_por_um_segredo_forte

# Opcional, recomendado em produção: cole aqui o certificado CA do Supabase
# (Project Settings > Database > SSL Configuration, em PEM) pra validar de
# verdade o certificado na conexão SSL com o banco. Sem essa variável, a
# conexão continua criptografada mas sem validar o certificado
# (rejectUnauthorized: false) — comportamento atual, mantido por padrão.
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Opcional: roda contra um schema Postgres diferente do padrão (public).
# Usado no ambiente de staging (PG_SCHEMA=zync_staging) — ver database/README.md.
# PG_SCHEMA=zync_staging

# URL pública deste backend (usada pro SyncPay chamar de volta o webhook)
BACKEND_PUBLIC_URL=http://localhost:3001

# URL(s) do frontend liberadas no CORS. A primeira da lista tambem e usada
# pra montar o link de redefinicao de senha. Aceita mais de uma, separadas
# por virgula (ex: producao + dominio alternativo de algum colega).
FRONTEND_URL=http://localhost:5500

# Credenciais da conta SyncPay (pegar no painel do SyncPay)
SYNCPAY_BASE_URL=
SYNCPAY_CLIENT_ID=
SYNCPAY_CLIENT_SECRET=
SYNCPAY_WEBHOOK_TOKEN=

# Token compartilhado pra autenticar o webhook do WhatsApp (header Authorization: Bearer <token>)
WHATSAPP_WEBHOOK_TOKEN=

# DSN do Sentry (sentry.io) pra captura de erros/exceções em produção.
# Sem essa variável, a captura fica desativada (ex: localmente, nos testes).
SENTRY_DSN=

# Envio de e-mail real via SendGrid (sendgrid.com). EMAIL_FROM precisa ser
# o e-mail verificado em Settings > Sender Authentication > Single Sender.
# Sem SENDGRID_API_KEY, o envio cai no mock (console.log) — ex: localmente, nos testes.
SENDGRID_API_KEY=
EMAIL_FROM=

# Tópico do ntfy.sh (https://ntfy.sh) pra alertar no celular sobre cadastro,
# login e pagamento aprovado (sem dado pessoal na mensagem — o nome do tópico
# funciona como uma "senha" fraca, quem souber recebe os alertas também).
# Sem essa variável, esses alertas ficam desativados.
NTFY_TOPIC=

# API key da Anthropic (console.anthropic.com) pra IA de atendimento real
# (Claude). Sem essa variável, cai no mock por palavra-chave — é o que
# acontece localmente/nos testes.
ANTHROPIC_API_KEY=

# Credenciais do WhatsApp Cloud API (Meta for Developers > seu app > WhatsApp
# > API Setup). WHATSAPP_PHONE_NUMBER_ID é o "Phone number ID" da Meta (não é
# o número de telefone). Sem essas duas variáveis, o envio cai no mock
# (console.log) — é o que acontece localmente/nos testes.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Webhook de RECEBIMENTO real do WhatsApp Cloud API (cadastrar a URL
# https://<seu-backend>/api/webhooks/whatsapp-meta no Meta for Developers >
# seu app > WhatsApp > Configuration). WHATSAPP_VERIFY_TOKEN é um valor que
# você escolhe e usa nos dois lados na hora de cadastrar a URL (handshake de
# verificação). WHATSAPP_APP_SECRET é o "App Secret" do app na Meta, usado
# pra validar a assinatura (header X-Hub-Signature-256) de cada mensagem
# recebida. Sem WHATSAPP_APP_SECRET, esse webhook fica bloqueado (503).
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
